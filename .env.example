# Password required to sign in at /admin
ADMIN_PASSWORD=change-me

# MongoDB Atlas connection string (Database > Connect > Drivers in the Atlas
# dashboard). Blog posts are stored in this database's "posts" collection
# and seeded from data/blog-posts.seed.json on first run.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Optional, defaults to "xpanix"
MONGODB_DB=xpanix

# Optional (recommended for production / Vercel deployments): create a Blob
# store in your Vercel project dashboard (Storage tab) and it will inject
# this token automatically. Used only for uploaded cover images. Without it,
# uploaded images are written to the local filesystem (public/uploads/),
# which does not persist on serverless hosting — use image URLs instead in
# that case.
BLOB_READ_WRITE_TOKEN=
